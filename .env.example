# LLM provider(s), comma-separated for fallback: "groq", "groq,gemini", "groq,groq,gemini"
LLM_PROVIDER=groq

# API key(s), comma-separated, one per provider entry
LLM_API_KEY=your-api-key-here

# Override the default model for the first provider (optional)
LLM_MODEL=

# GitHub token for reading repo data and publishing the changelog
GITHUB_TOKEN=ghp_your-token-here

# Output language: "english", "italian", "french", "spanish", "german"
CHANGELOG_LANGUAGE=english

# Whether to commit CHANGELOG.md ("true" / "false")
UPDATE_CHANGELOG_FILE=false

# Path to the CHANGELOG.md file
CHANGELOG_FILE_PATH=CHANGELOG.md

# Maximum number of commits to include in the LLM context
MAX_COMMITS=100

# Maximum number of merged PRs to include in the LLM context
MAX_PRS=30

# Self-evaluation retry count (0 to disable)
MAX_EVAL_RETRIES=1

# Repository full name (owner/repo) - injected by GitHub Actions
REPO_FULL_NAME=owner/repo

# Release tag - injected by GitHub Actions
RELEASE_TAG=v1.0.0

# Release name - injected by GitHub Actions
RELEASE_NAME=v1.0.0

# Release ID - injected by GitHub Actions (empty on tag push)
RELEASE_ID=

# Default branch - injected by GitHub Actions
DEFAULT_BRANCH=main
